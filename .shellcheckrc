# LitigationOS ShellCheck Configuration
# Applied per shellcheck-configuration skill standards
# Target: All .sh scripts in repo (Termux, Neo4j import, tools)

# Default shell dialect — most scripts target bash
shell=bash

# Enable optional checks for stricter analysis
enable=avoid-nullary-conditions
enable=require-variable-braces

# Disable known false positives for this project:
# SC1091: Not following sourced files (many cross-directory sources)
disable=SC1091

# SC2034: Variable appears unused (many scripts export for child processes)
disable=SC2034

# SC2154: Variable referenced but not assigned (set by parent shell/Termux)
disable=SC2154

# Allow external source directives
external-sources=true
