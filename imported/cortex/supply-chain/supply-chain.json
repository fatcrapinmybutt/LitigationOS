{
  "$schema": "https://cortex-graph.dev/schemas/domain-pack-v2.json",
  "id": "cortex-supply-chain",
  "name": "CORTEX Supply Chain Intelligence",
  "version": "1.0.0",
  "description": "Supply chain risk monitoring, vendor assessment, sanctions screening, and logistics intelligence for knowledge graph analysis.",
  "author": "Andrew Pioneer",
  "license": "MIT",
  "homepage": "https://fatcrapinmybutt.github.io/cortex-site/",
  "purchase_url": "https://andrewpioneer6.gumroad.com/l/cjamvzo",
  "domain": "supply-chain",
  "tags": [
    "supply-chain",
    "risk-management",
    "sanctions-screening",
    "vendor-assessment",
    "logistics-intelligence",
    "procurement",
    "compliance",
    "osint",
    "trade",
    "cortex"
  ],

  "entity_types": {
    "supplier": {
      "label": "Supplier",
      "description": "Tier 1-3 suppliers providing goods or services within the supply network",
      "shape": "hexagon",
      "color": "#4CAF50",
      "icon": "factory",
      "properties": ["name", "tier_level", "country", "risk_score", "revenue", "certifications", "lead_time_days", "payment_terms", "diversity_status"],
      "patterns": [
        "(?i)\\b(?:supplier|vendor|provider|source|subcontractor)\\b",
        "(?i)\\btier[- ]?[123]\\b",
        "(?i)\\b(?:sole[- ]source|single[- ]source|approved supplier)\\b"
      ]
    },
    "manufacturer": {
      "label": "Manufacturer",
      "description": "Production facilities and contract manufacturers with capacity data",
      "shape": "octagon",
      "color": "#FF9800",
      "icon": "precision_manufacturing",
      "properties": ["name", "country", "facility_type", "capacity_units", "certifications", "lead_time", "quality_rating", "workforce_size"],
      "patterns": [
        "(?i)\\b(?:manufacturer|factory|plant|production facility|OEM|contract manufacturer|CMO|CDMO)\\b",
        "(?i)\\b(?:assembly line|production line|fabrication)\\b"
      ]
    },
    "distributor": {
      "label": "Distributor",
      "description": "Distribution network nodes handling product movement and regional fulfillment",
      "shape": "diamond",
      "color": "#2196F3",
      "icon": "local_shipping",
      "properties": ["name", "region", "channels", "warehouse_count", "delivery_sla", "coverage_area"],
      "patterns": [
        "(?i)\\b(?:distributor|wholesaler|reseller|channel partner|3PL|logistics provider)\\b",
        "(?i)\\b(?:distribution center|DC|fulfillment center)\\b"
      ]
    },
    "port": {
      "label": "Port",
      "description": "Maritime ports, terminals, and intermodal hubs",
      "shape": "triangle",
      "color": "#00BCD4",
      "icon": "anchor",
      "properties": ["name", "country", "port_code", "type", "capacity_teu", "congestion_index", "avg_dwell_time", "customs_clearance_time"],
      "patterns": [
        "(?i)\\b(?:port of|seaport|terminal|harbor|harbour|berth|anchorage)\\b",
        "(?i)\\b(?:TEU|twenty-foot equivalent|container terminal)\\b",
        "(?i)\\bUN/?LOCODE\\s*[A-Z]{2}[A-Z0-9]{3}\\b"
      ]
    },
    "warehouse": {
      "label": "Warehouse",
      "description": "Storage, staging, and fulfillment facilities",
      "shape": "square",
      "color": "#795548",
      "icon": "warehouse",
      "properties": ["name", "location", "sqft", "type", "temperature_controlled", "bonded", "ftz_status", "throughput_units_day"],
      "patterns": [
        "(?i)\\b(?:warehouse|storage facility|depot|stockroom|bonded warehouse|FTZ|foreign trade zone)\\b",
        "(?i)\\b(?:cold storage|frozen storage|ambient storage|cross-dock)\\b"
      ]
    },
    "commodity": {
      "label": "Commodity",
      "description": "Raw materials, components, and traded goods",
      "shape": "circle",
      "color": "#FFC107",
      "icon": "category",
      "properties": ["name", "hs_code", "category", "unit_of_measure", "price_benchmark", "origin_countries", "critical_mineral", "conflict_mineral"],
      "patterns": [
        "(?i)\\b(?:commodity|raw material|component|feedstock|input material|precursor)\\b",
        "(?i)\\b(?:rare earth|lithium|cobalt|palladium|tungsten|tantalum|tin|gold|3TG)\\b",
        "(?i)\\bHS\\s*\\d{4,10}\\b"
      ]
    },
    "trade_route": {
      "label": "Trade Route",
      "description": "Shipping lanes, corridors, and transportation routes",
      "shape": "parallelogram",
      "color": "#3F51B5",
      "icon": "route",
      "properties": ["name", "origin", "destination", "mode", "transit_days", "cost_per_unit", "risk_level", "chokepoints"],
      "patterns": [
        "(?i)\\b(?:trade route|shipping lane|corridor|transit route|supply corridor)\\b",
        "(?i)\\b(?:Suez Canal|Panama Canal|Strait of Malacca|Strait of Hormuz|Cape of Good Hope|Bab el-Mandeb)\\b"
      ]
    },
    "sanction_entity": {
      "label": "Sanction Entity",
      "description": "Entities on OFAC SDN, BIS Entity List, EU sanctions, or other denied party lists",
      "shape": "star",
      "color": "#F44336",
      "icon": "block",
      "properties": ["name", "list_source", "designation_date", "program", "sdn_type", "aliases", "addresses", "id_numbers"],
      "patterns": [
        "(?i)\\b(?:SDN|specially designated national|sanctioned entity|blocked person|denied party)\\b",
        "(?i)\\b(?:OFAC|entity list|denied persons list|unverified list|military end.?user)\\b",
        "(?i)\\b(?:EAR\\s*§?\\s*7[4-6]\\d)\\b"
      ]
    },
    "contract": {
      "label": "Contract",
      "description": "Procurement agreements, purchase orders, and framework contracts",
      "shape": "rectangle",
      "color": "#607D8B",
      "icon": "description",
      "properties": ["contract_id", "type", "value", "currency", "start_date", "end_date", "renewal_terms", "penalties", "incoterms"],
      "patterns": [
        "(?i)\\b(?:contract|purchase order|PO|framework agreement|blanket order|MSA|master service agreement)\\b",
        "(?i)\\b(?:Incoterms|FOB|CIF|DDP|EXW|FCA|DAP)\\b"
      ]
    },
    "regulatory_body": {
      "label": "Regulatory Body",
      "description": "Government agencies, standards bodies, and regulatory authorities",
      "shape": "pentagon",
      "color": "#9C27B0",
      "icon": "account_balance",
      "properties": ["name", "jurisdiction", "authority_type", "website", "enforcement_actions"],
      "patterns": [
        "(?i)\\b(?:OFAC|BIS|CBP|FDA|USDA|EPA|OSHA|CPSC|FTC|SEC|DOJ)\\b",
        "(?i)\\b(?:European Commission|DG Trade|BAFA|METI|customs authority)\\b"
      ]
    },
    "country": {
      "label": "Country",
      "description": "Geopolitical risk zone with country-level risk scoring",
      "shape": "hexagon",
      "color": "#009688",
      "icon": "public",
      "properties": ["name", "iso_code", "region", "risk_tier", "sanctions_programs", "trade_agreements", "corruption_index", "political_stability_score"],
      "patterns": [
        "(?i)\\bcountry[- ]?(?:of origin|risk|exposure)\\b",
        "(?i)\\b(?:embargo|embargoed country|high-risk jurisdiction|sanctioned country)\\b"
      ]
    },
    "beneficial_owner": {
      "label": "Beneficial Owner",
      "description": "Ultimate beneficial owners and corporate ownership chains",
      "shape": "circle",
      "color": "#E91E63",
      "icon": "person",
      "properties": ["name", "nationality", "ownership_pct", "pep_status", "adverse_media", "sanctions_hit"],
      "patterns": [
        "(?i)\\b(?:beneficial owner|UBO|ultimate beneficial|controlling person|shareholder|stakeholder)\\b",
        "(?i)\\b(?:PEP|politically exposed person|state-owned enterprise|SOE)\\b"
      ]
    },
    "quality_event": {
      "label": "Quality Event",
      "description": "Defects, recalls, audit failures, and corrective actions",
      "shape": "diamond",
      "color": "#FF5722",
      "icon": "report_problem",
      "properties": ["event_id", "type", "severity", "root_cause", "affected_lots", "corrective_action", "capa_status", "cost_impact"],
      "patterns": [
        "(?i)\\b(?:quality event|defect|nonconformance|NCR|recall|audit finding|CAPA|corrective action)\\b",
        "(?i)\\b(?:rejection|out.?of.?spec|OOS|deviation|complaint)\\b"
      ]
    },
    "transaction": {
      "label": "Transaction",
      "description": "Financial flows, payments, and trade finance instruments",
      "shape": "rectangle",
      "color": "#4DB6AC",
      "icon": "payments",
      "properties": ["transaction_id", "type", "amount", "currency", "date", "counterparty", "payment_method", "lc_number"],
      "patterns": [
        "(?i)\\b(?:transaction|payment|wire transfer|letter of credit|L/?C|trade finance|invoice)\\b",
        "(?i)\\b(?:SWIFT|MT103|MT700|documentary collection)\\b"
      ]
    },
    "kpi_metric": {
      "label": "KPI Metric",
      "description": "Supply chain performance measurement and benchmarking nodes",
      "shape": "circle",
      "color": "#8BC34A",
      "icon": "analytics",
      "properties": ["metric_name", "value", "unit", "target", "trend", "period", "data_source"],
      "patterns": [
        "(?i)\\b(?:KPI|metric|SLA|OTD|on.?time delivery|fill rate|OTIF|perfect order)\\b",
        "(?i)\\b(?:cycle time|lead time|inventory turns|days.?of.?supply|stockout rate)\\b"
      ]
    },
    "freight_forwarder": {
      "label": "Freight Forwarder",
      "description": "Logistics intermediaries handling shipment coordination",
      "shape": "diamond",
      "color": "#5C6BC0",
      "icon": "flight",
      "properties": ["name", "modes", "regions", "fmc_license", "iata_code", "customs_broker_license", "c_tpat_status"],
      "patterns": [
        "(?i)\\b(?:freight forwarder|NVOCC|customs broker|shipping agent|logistics company|4PL)\\b",
        "(?i)\\b(?:FMC license|IATA agent|customs brokerage)\\b"
      ]
    },
    "customs_entry": {
      "label": "Customs Entry",
      "description": "Import/export declarations and customs filings",
      "shape": "square",
      "color": "#78909C",
      "icon": "inventory",
      "properties": ["entry_number", "entry_type", "port_of_entry", "hs_codes", "value", "duties_paid", "broker", "release_date"],
      "patterns": [
        "(?i)\\b(?:customs entry|entry summary|7501|import declaration|export declaration|AES|ABI)\\b",
        "(?i)\\b(?:CF-?28|CF-?29|notice of action|rate advance|protest)\\b"
      ]
    },
    "compliance_record": {
      "label": "Compliance Record",
      "description": "Certifications, audit results, and regulatory compliance artifacts",
      "shape": "shield",
      "color": "#66BB6A",
      "icon": "verified",
      "properties": ["record_id", "type", "standard", "status", "issue_date", "expiry_date", "auditor", "scope"],
      "patterns": [
        "(?i)\\b(?:ISO\\s*\\d{4,5}|SA8000|SMETA|BSCI|RBA|CTPAT|AEO|FSSC 22000)\\b",
        "(?i)\\b(?:certification|audit report|compliance certificate|accreditation|registration)\\b"
      ]
    },
    "disruption_event": {
      "label": "Disruption Event",
      "description": "Natural disasters, strikes, factory shutdowns, and force majeure events",
      "shape": "burst",
      "color": "#D32F2F",
      "icon": "warning",
      "properties": ["event_id", "type", "severity", "location", "start_date", "end_date", "affected_suppliers", "estimated_impact", "recovery_time"],
      "patterns": [
        "(?i)\\b(?:disruption|force majeure|natural disaster|earthquake|typhoon|flood|strike|lockout|shutdown|pandemic)\\b",
        "(?i)\\b(?:port closure|border closure|embargo|export ban|raw material shortage)\\b"
      ]
    },
    "esg_factor": {
      "label": "ESG Factor",
      "description": "Environmental, social, and governance risk signals across the supply chain",
      "shape": "leaf",
      "color": "#2E7D32",
      "icon": "eco",
      "properties": ["factor_type", "category", "severity", "source", "supplier_link", "remediation_status", "scope_category"],
      "patterns": [
        "(?i)\\b(?:ESG|environmental|social|governance|sustainability|carbon footprint|scope [123])\\b",
        "(?i)\\b(?:child labor|forced labor|deforestation|water stress|biodiversity|human rights)\\b",
        "(?i)\\b(?:GHG|greenhouse gas|CDP|SBTi|TCFD|GRI|SASB)\\b"
      ]
    },
    "bill_of_lading": {
      "label": "Bill of Lading",
      "description": "Shipping documentation and transport evidence",
      "shape": "rectangle",
      "color": "#90A4AE",
      "icon": "receipt_long",
      "properties": ["bl_number", "type", "shipper", "consignee", "notify_party", "vessel", "voyage", "port_of_loading", "port_of_discharge", "containers"],
      "patterns": [
        "(?i)\\b(?:bill of lading|B/?L|waybill|AWB|air waybill|sea waybill|multimodal transport)\\b",
        "(?i)\\b(?:SCAC code|booking number|container number|[A-Z]{4}\\d{7})\\b"
      ]
    },
    "hs_code": {
      "label": "HS Code",
      "description": "Harmonized System tariff classification codes",
      "shape": "tag",
      "color": "#FFB74D",
      "icon": "label",
      "properties": ["code", "description", "chapter", "duty_rate", "fta_eligibility", "export_control_classification", "anti_dumping_order"],
      "patterns": [
        "(?i)\\bH\\.?S\\.?\\s*(?:code|tariff)?\\s*\\d{4,10}\\b",
        "(?i)\\bHTS(?:US)?\\s*\\d{4,10}\\b",
        "(?i)\\b(?:tariff classification|Schedule B|ECCN)\\b"
      ]
    },
    "insurance_policy": {
      "label": "Insurance Policy",
      "description": "Cargo, marine, liability, and trade credit insurance coverage",
      "shape": "shield",
      "color": "#AB47BC",
      "icon": "shield",
      "properties": ["policy_number", "type", "carrier", "coverage_amount", "deductible", "effective_date", "expiry_date", "perils_covered"],
      "patterns": [
        "(?i)\\b(?:cargo insurance|marine insurance|trade credit insurance|product liability|CGL|inland marine)\\b",
        "(?i)\\b(?:certificate of insurance|COI|Institute Cargo Clauses|war risk)\\b"
      ]
    },
    "raw_material": {
      "label": "Raw Material",
      "description": "Upstream material inputs, critical minerals, and feedstock",
      "shape": "cylinder",
      "color": "#A1887F",
      "icon": "science",
      "properties": ["name", "type", "origin_country", "criticality", "price_volatility", "substitutability", "recycled_content_pct"],
      "patterns": [
        "(?i)\\b(?:raw material|critical mineral|strategic material|feedstock|precursor chemical)\\b",
        "(?i)\\b(?:lithium|cobalt|nickel|copper|aluminum|steel|semiconductor|chip|wafer)\\b"
      ]
    },
    "iot_sensor": {
      "label": "IoT Sensor",
      "description": "Real-time tracking and monitoring telemetry from supply chain assets",
      "shape": "dot",
      "color": "#26C6DA",
      "icon": "sensors",
      "properties": ["sensor_id", "type", "location", "asset_linked", "last_reading", "alert_threshold", "battery_level"],
      "patterns": [
        "(?i)\\b(?:IoT|sensor|GPS tracker|temperature logger|humidity monitor|shock sensor|geofence)\\b",
        "(?i)\\b(?:RFID|NFC|BLE beacon|LoRaWAN|cellular tracker)\\b"
      ]
    }
  },

  "categories": [
    {
      "id": "logistics",
      "label": "Logistics & Transportation",
      "description": "Port congestion, route optimization, carrier performance, lead time analysis",
      "color": "#2196F3",
      "keywords": ["shipping", "freight", "carrier", "transit", "drayage", "intermodal", "last mile"]
    },
    {
      "id": "compliance",
      "label": "Regulatory Compliance",
      "description": "Export controls, sanctions adherence, customs compliance, trade regulations",
      "color": "#9C27B0",
      "keywords": ["regulation", "compliance", "audit", "certification", "license", "permit"]
    },
    {
