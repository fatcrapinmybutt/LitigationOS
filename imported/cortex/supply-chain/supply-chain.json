  "authority_patterns": [
    {
      "id": "ofac",
      "label": "OFAC Sanctions",
      "description": "Office of Foreign Assets Control — SDN List, Sectoral Sanctions, country programs",
      "patterns": [
        "(?i)\\bOFAC\\b",
        "(?i)\\bSDN\\s*(?:list)?\\b",
        "(?i)\\b(?:specially designated national|blocked person|sectoral sanctions)\\b",
        "(?i)\\b31\\s*C\\.?F\\.?R\\.?\\s*Part\\s*5(?:01|10|15|37|38|42|44|46|48|60|61|76|88|89|90)\\b",
        "(?i)\\bExecutive\\s+Order\\s+1(?:3224|3382|3599|3662|3694|3722|13846|14024)\\b"
      ],
      "jurisdiction": "United States",
      "authority_type": "sanctions"
    },
    {
      "id": "bis_export",
      "label": "BIS Export Controls",
      "description": "Bureau of Industry and Security — Entity List, EAR, export licensing",
      "patterns": [
        "(?i)\\bBIS\\b(?!.*\\bbasis\\b)",
        "(?i)\\bEntity\\s+List\\b",
        "(?i)\\b(?:EAR|Export Administration Regulations)\\b",
        "(?i)\\bECCN\\s*[0-9][A-E]\\d{3}\\b",
        "(?i)\\b15\\s*C\\.?F\\.?R\\.?\\s*Parts?\\s*7(?:30|32|34|36|38|40|42|44|46|48|50|52|54|56|58|62|64|66|68|72|74)\\b",
        "(?i)\\b(?:denied persons list|unverified list|military end.?user list)\\b"
      ],
      "jurisdiction": "United States",
      "authority_type": "export_control"
    },
    {
      "id": "cbp_customs",
      "label": "CBP Customs Regulations",
      "description": "Customs and Border Protection — import requirements, duties, forced labor (UFLPA)",
      "patterns": [
        "(?i)\\bCBP\\b",
        "(?i)\\b19\\s*C\\.?F\\.?R\\.?\\b",
        "(?i)\\b(?:UFLPA|Uyghur Forced Labor Prevention Act)\\b",
        "(?i)\\b(?:withhold release order|WRO|finding of forced labor)\\b",
        "(?i)\\b(?:AD/?CVD|antidumping|countervailing duty)\\b",
        "(?i)\\b(?:Section 301|Section 201|Section 232)\\s*(?:tariff|duty|action)\\b"
      ],
      "jurisdiction": "United States",
      "authority_type": "customs"
    },
    {
      "id": "iso_standards",
      "label": "ISO Standards",
      "description": "International Organization for Standardization quality and management systems",
      "patterns": [
        "(?i)\\bISO\\s*(?:9001|14001|45001|22000|28000|27001|31000|20400|50001|13485|17025)\\b",
        "(?i)\\b(?:IATF 16949|AS9100|FSSC 22000|SA8000)\\b"
      ],
      "jurisdiction": "International",
      "authority_type": "standard"
    },
    {
      "id": "fcpa_bribery",
      "label": "FCPA & Anti-Corruption",
      "description": "Foreign Corrupt Practices Act, UK Bribery Act — anti-corruption compliance",
      "patterns": [
        "(?i)\\bFCPA\\b",
        "(?i)\\b(?:Foreign Corrupt Practices Act)\\b",
        "(?i)\\b(?:UK Bribery Act|Bribery Act 2010)\\b",
        "(?i)\\b(?:facilitation payment|grease payment|PEP screening|anti.?bribery)\\b"
      ],
      "jurisdiction": "International",
      "authority_type": "anti_corruption"
    },
    {
      "id": "conflict_minerals",
      "label": "Conflict Minerals",
      "description": "Dodd-Frank Section 1502, EU Conflict Minerals Regulation — 3TG due diligence",
      "patterns": [
        "(?i)\\b(?:conflict minerals?|3TG|tin|tantalum|tungsten|gold)\\b(?=.*(?:due diligence|conflict|DRC|Congo))",
        "(?i)\\bDodd.?Frank\\s*(?:Section|§)?\\s*1502\\b",
        "(?i)\\b(?:EU (?:Conflict )?Minerals? Regulation|Regulation \\(EU\\) 2017/821)\\b",
        "(?i)\\b(?:CMRT|Conflict Minerals Reporting Template|RMI|Responsible Minerals Initiative)\\b"
      ],
      "jurisdiction": "International",
      "authority_type": "due_diligence"
    },
    {
      "id": "trade_agreements",
      "label": "Trade Agreements",
      "description": "USMCA, EU FTAs, CPTPP — rules of origin, preferential tariff treatment",
      "patterns": [
        "(?i)\\b(?:USMCA|NAFTA|CPTPP|TPP|RCEP|CETA|EVFTA)\\b",
        "(?i)\\b(?:rules? of origin|certificate of origin|preferential tariff|GSP)\\b",
