# === DATABASES (too large for GitHub, >100 MB) ===
*.db
*.db-shm
*.db-wal
*.db.7z
*.sqlite
*.sqlite3
!00_SYSTEM/brains/.gitkeep

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.pkl
*.pickle
00_SYSTEM/engines/predictive/models/

# === Virtual Environments ===
pytools_venv/
.venv/
venv/
env/
.env

# === Node.js ===
node_modules/
npm-debug.log*
package-lock.json

# === Go ===
*.exe
!scripts/*.exe

# === OS Files ===
Thumbs.db
Desktop.ini
.DS_Store
*.tmp
*.temp
*.swp
*~

# === IDE ===
.idea/
.vscode/settings.json
*.sublime-*

# === Large/Generated Content ===
*.7z
*.zip
*.tar.gz
*.rar

# === Logs ===
logs/
*.log

# === Temp ===
temp/
patches/

