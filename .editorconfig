# EditorConfig — LitigationOS
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.{json,jsonc,yaml,yml,toml}]
indent_size = 2

[*.{md,txt}]
trim_trailing_whitespace = false

[*.{html,css,js,ts,tsx,jsx}]
indent_size = 2

[*.{typ}]
indent_size = 2

[*.{bat,cmd,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab

[justfile]
indent_size = 4
