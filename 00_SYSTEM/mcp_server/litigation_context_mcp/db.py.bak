# ── Error Infrastructure ──────────────────────────────────────────
class ErrorCode(Enum):
    ERR_DB_CONNECT = "ERR_DB_CONNECT"
    ERR_PDF_PERMISSION = "ERR_PDF_PERMISSION"
    ERR_PDF_TIMEOUT = "ERR_PDF_TIMEOUT"
    ERR_FTS_SYNTAX = "ERR_FTS_SYNTAX"
    ERR_DB_LOCKED = "ERR_DB_LOCKED"


_RECOVERY_HINTS: dict[ErrorCode, str] = {
    ErrorCode.ERR_DB_CONNECT: (
        "Check that litigation_context.db exists and is not corrupted. "
        "Verify LITIGATION_DB_PATH env var. Try: PRAGMA integrity_check;"
    ),
    ErrorCode.ERR_PDF_PERMISSION: (
        "The PDF file is locked or read-protected. Close any application "
        "that has the file open and retry."
    ),
    ErrorCode.ERR_PDF_TIMEOUT: (
        "PDF extraction timed out — the file may be very large or encrypted. "
        "Try a smaller file or check for password protection."
    ),
    ErrorCode.ERR_FTS_SYNTAX: (
        "The search query has invalid FTS5 syntax. Use simple keywords, "
        '"quoted phrases", AND/OR/NOT operators, or prefix* wildcards.'
    ),
    ErrorCode.ERR_DB_LOCKED: (
        "Another process holds a write lock. Wait a few seconds and retry. "
        "If persistent, check for long-running pipeline phases."
    ),
}


class DatabaseError(Exception):
    """General database error."""


class StructuredError(Exception):
    """Error with a machine-readable code, human message, and recovery hint."""

    def __init__(
        self,
        code: ErrorCode,
        message: str,
        original_exception: Exception | None = None,
    ):
        self.code = code
        self.message = message
        self.original_exception = original_exception
        self.hint = _RECOVERY_HINTS.get(code, "No recovery hint available.")
        super().__init__(f"{code.value}: {message}")


# ── Circuit Breaker ───────────────────────────────────────────────
class _CircuitBreaker:
    """Simple circuit breaker for DB connections."""

    CLOSED = "closed"
    OPEN = "open"
    HALF_OPEN = "half_open"

    def __init__(self, threshold: int = 5, reset_timeout: float = 60.0):
        self.threshold = threshold
        self.reset_timeout = reset_timeout
        self.failure_count = 0
        self.state = self.CLOSED
        self._last_failure: float = 0.0

    def record_failure(self):
        self.failure_count += 1
        self._last_failure = time.time()
        if self.failure_count >= self.threshold:
            self.state = self.OPEN

    def record_success(self):
        self.failure_count = 0
        self.state = self.CLOSED

    def allow_request(self) -> bool:
        if self.state == self.CLOSED:
            return True
        if self.state == self.OPEN:
            if time.time() - self._last_failure >= self.reset_timeout:
                self.state = self.HALF_OPEN
                return True
            return False
        # HALF_OPEN — allow one attempt
        return True

    def reset(self):
        self.failure_count = 0
        self.state = self.CLOSED
        self._last_failure = 0.0

    @property
    def status(self) -> dict:
        return {
            "state": self.state,
            "failure_count": self.failure_count,
            "threshold": self.threshold,
            "reset_timeout_s": self.reset_timeout,
        }


_db_circuit = _CircuitBreaker()


# ── Health Status ─────────────────────────────────────────────────
class HealthStatus:
    """Server health singleton tracked across the MCP lifespan."""

    def __init__(self):
        self.startup_time: str | None = None
        self.graphs_loaded: bool = False
        self.graph_errors: list[str] = []
        self.degraded: bool = False

    @property
    def status(self) -> dict:
        return {
            "startup_time": self.startup_time,
            "graphs_loaded": self.graphs_loaded,
            "graph_errors": self.graph_errors,
            "degraded": self.degraded,
            "circuit_breaker": _db_circuit.status,
        }


health = HealthStatus()


# ── Helpers ───────────────────────────────────────────────────────
def _table_exists(conn: sqlite3.Connection, table_name: str) -> bool:
    """Check whether a table exists in the database."""
    row = conn.execute(
        "SELECT COUNT(*) FROM sqlite_master WHERE type='table' AND name=?",
        (table_name,),
    ).fetchone()
    return row[0] > 0


def _safe_fetchone(conn: sqlite3.Connection, sql: str, params=()) -> sqlite3.Row | None:
    try:
        return conn.execute(sql, params).fetchone()
    except sqlite3.OperationalError:
        return None


# ── Connection ────────────────────────────────────────────────────
_SCHEMA_DDL = """
CREATE TABLE IF NOT EXISTS documents (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    file_path TEXT UNIQUE NOT NULL,
    file_name TEXT NOT NULL,
    file_size_bytes INTEGER,
    modified_date TEXT,
    page_count INTEGER DEFAULT 0,
    sha256_hash TEXT,
    ingested_at TEXT DEFAULT (datetime('now'))
);

CREATE TABLE IF NOT EXISTS pages (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    document_id INTEGER NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
    page_number INTEGER NOT NULL,
    text_content TEXT,
    char_count INTEGER DEFAULT 0
);

CREATE VIRTUAL TABLE IF NOT EXISTS pages_fts USING fts5(
    text_content,
    content='pages',
    content_rowid='id',
    tokenize='porter unicode61'
);

CREATE TABLE IF NOT EXISTS graph_nodes (
    id TEXT NOT NULL,
    node_type TEXT,
    label TEXT,
    data TEXT,
    graph_source TEXT NOT NULL,
    loaded_at TEXT DEFAULT (datetime('now')),
    PRIMARY KEY (id, graph_source)
);

CREATE TABLE IF NOT EXISTS graph_edges (
    source_id TEXT NOT NULL,
    target_id TEXT NOT NULL,
    edge_type TEXT,
    data TEXT,
    graph_source TEXT NOT NULL,
    loaded_at TEXT DEFAULT (datetime('now'))
);

CREATE TABLE IF NOT EXISTS risk_events (
    risk_type_id TEXT PRIMARY KEY,
    title TEXT,
    severity INTEGER DEFAULT 0,
    risk_class TEXT,
    track TEXT,
    forum TEXT,
    cure_cost TEXT,
    cure_deadline_clock TEXT,
    cure_packet_json TEXT,
    trigger_json TEXT,
    authority_json TEXT,
    loaded_at TEXT DEFAULT (datetime('now'))
);

CREATE TABLE IF NOT EXISTS md_sections (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    source_file TEXT NOT NULL,
    source_path TEXT NOT NULL,
    section_level INTEGER DEFAULT 1,
    section_title TEXT,
    section_path TEXT,
    content TEXT,
    evolved_at TEXT DEFAULT (datetime('now'))
);

CREATE VIRTUAL TABLE IF NOT EXISTS md_sections_fts USING fts5(
    section_title,
    content,
    content='md_sections',
    content_rowid='id',
    tokenize='porter unicode61'
);

CREATE TABLE IF NOT EXISTS md_cross_refs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    section_id INTEGER REFERENCES md_sections(id),
    ref_type TEXT,
    ref_value TEXT,
    confidence REAL DEFAULT 0.5,
    graph_node_id TEXT,
    graph_source TEXT,
