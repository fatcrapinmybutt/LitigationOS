{
  "name": "litigation-os-desktop",
  "version": "1.0.0",
  "description": "LitigationOS Desktop — Production-ready litigation intelligence platform",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "dev:renderer": "next dev src/renderer -p 3000",
    "dev:electron": "electron .",
    "build": "next build src/renderer && electron-builder",
    "build:renderer": "next build src/renderer",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.litigationos.desktop",
    "productName": "LitigationOS",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "src/main/**/*",
      "src/renderer/out/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../../",
        "to": "app",
        "filter": [
          "!node_modules/**",
          "!.git/**",
          "!**/dist/**",
          "!**/.next/**",
          "!**/__pycache__/**",
          "!**/*.db",
          "!**/chroma_db/**",
          "!**/chromadb_store/**",
          "!**/training_data/**",
          "!**/local_model/**"
        ]
      }
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-updater": "^6.2.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0"
  }
}
