# ===== Ports =====
WEBHOOK_PORT=8787

# ===== Storage =====
WEBHOOK_INBOX_DIR=./data/inbox
WEBHOOK_PROCESSED_DIR=./data/processed
WEBHOOK_REGISTRY_FILE=./data/registry/hooks.json

# ===== Optional verification secrets =====
# GitHub: used when a hook config has provider=github and secretEnv points here
GITHUB_WEBHOOK_SECRET=change-me

# ===== Performance =====
# Maximum payload bytes accepted (default 5MB)
MAX_BODY_BYTES=5242880
