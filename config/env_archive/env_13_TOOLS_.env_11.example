# LitigationOS dev container defaults.
# This file is safe to commit. Copy to .env for local overrides.
TZ=America/Detroit

# Neo4j (compose DNS: neo4j)
NEO4J_URI=bolt://neo4j:7687
NEO4J_HTTP=http://neo4j:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_change_me

# Qdrant (compose DNS: qdrant)
QDRANT_URL=http://qdrant:6333

# Apache Tika (compose DNS: tika)
TIKA_URL=http://tika:9998

# Local workspace paths inside container
LITIGATIONOS_ROOT=/workspace
LITIGATIONOS_DATA=/workspace/_data
LITIGATIONOS_RUNS=/workspace/_runs
