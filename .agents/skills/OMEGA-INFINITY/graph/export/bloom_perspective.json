  "searchPhrases": [
    {
      "name": "All evidence for a lane",
      "cypher": "MATCH (e:Evidence)-[:EVIDENCE_IN_LANE]->(l:Lane {code: $lane}) RETURN e, l LIMIT 200"
    },
    {
      "name": "Judicial violations",
      "cypher": "MATCH (j:Judge)-[:HAS_VIOLATION]->(v:Violation) RETURN j, v LIMIT 200"
    },
    {
      "name": "Filing dependencies",
      "cypher": "MATCH (f:Filing)-[:USES_FORM]->(form:Form) RETURN f, form"
    },
    {
      "name": "Case parties",
      "cypher": "MATCH (c:Case)-[:INVOLVES_PARTY]->(p:Party) RETURN c, p"
    },
    {
      "name": "Timeline",
      "cypher": "MATCH (e1:Event)-[:NEXT_EVENT]->(e2:Event) RETURN e1, e2 LIMIT 100"
    }
  ]
}